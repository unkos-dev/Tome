# Staging bootstrap env template — copied to `docker/.env` on the host
# (gitignored). Real values are managed by the host secret-management
# agent; this file is the spec, not the source of truth.
#
# Compose auto-loads `.env` from the project directory and uses it to
# resolve `${VAR}` interpolation in compose.staging.yml. Postgres-bootstrap
# vars belong here so they are scoped to the postgres service via the
# explicit `environment:` block — the reverie container does NOT receive
# POSTGRES superuser credentials.
#
# Application-runtime vars (DATABASE_URL, OIDC secrets, REVERIE_* config)
# live in a separate file — see `staging.env.runtime.example`.

# Postgres bootstrap (consumed by postgres:18-alpine entrypoint).
POSTGRES_USER=reverie
POSTGRES_PASSWORD=
POSTGRES_DB=reverie

# Runtime-role passwords used by docker/init-roles.sql at fresh-volume
# init. Must match the password embedded in DATABASE_URL /
# INGESTION_DATABASE_URL set in `staging.env.runtime.example` —
# divergence will produce a 28P01 authentication failure at startup.
REVERIE_APP_PASSWORD=
REVERIE_INGESTION_PASSWORD=
REVERIE_READONLY_PASSWORD=

# Image tag — driven by the deploy script, bumped per release. Used for
# `${REVERIE_VERSION:?required}` interpolation in compose.staging.yml.
REVERIE_VERSION=0.1.0
