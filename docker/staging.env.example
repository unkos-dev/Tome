# Staging deploy env template — used by docker/compose.staging.yml.
# Copy to docker/.env on the host and populate (gitignored). Real values
# are managed by the host secret-management agent; this file is the spec,
# not the source of truth.

# Postgres bootstrap (consumed by postgres:18-alpine entrypoint).
POSTGRES_USER=reverie
POSTGRES_PASSWORD=
POSTGRES_DB=reverie

# Runtime-role passwords used by docker/init-roles.sql at fresh-volume
# init. Must match the password embedded in DATABASE_URL /
# INGESTION_DATABASE_URL — divergence will produce a 28P01
# authentication-failure at startup.
REVERIE_APP_PASSWORD=
REVERIE_INGESTION_PASSWORD=
REVERIE_READONLY_PASSWORD=

# Reverie runtime — uses non-superuser roles created by init-roles.sql.
DATABASE_URL=postgres://reverie_app:<password>@reverie-postgres:5432/reverie
INGESTION_DATABASE_URL=postgres://reverie_ingestion:<password>@reverie-postgres:5432/reverie

# SPA dist served by the backend; matches Dockerfile COPY target.
REVERIE_FRONTEND_DIST_PATH=/srv/frontend

# Image tag — driven by the deploy script, bumped per release.
REVERIE_VERSION=0.1.0

# Reverie config (subset — see backend/CLAUDE.md and docs/security/ for full).
REVERIE_PORT=3000
REVERIE_OPERATOR_CONTACT=
REVERIE_LOG_LEVEL=info

# OIDC (if integrated — gate provisioning is out-of-tree).
REVERIE_OIDC_ISSUER_URL=
REVERIE_OIDC_CLIENT_ID=
REVERIE_OIDC_CLIENT_SECRET=
REVERIE_OIDC_REDIRECT_URL=
