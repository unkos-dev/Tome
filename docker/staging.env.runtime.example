# Staging runtime env template — copied to `docker/.env.runtime` on the
# host (gitignored). Real values are managed by the host
# secret-management agent; this file is the spec, not the source of truth.
#
# Loaded only by the `reverie` service via `env_file:` in
# compose.staging.yml. Kept separate from `staging.env.bootstrap.example`
# so postgres-bootstrap superuser credentials never reach the application
# container — a compromised reverie container reading `/proc/<pid>/environ`
# only sees the non-superuser DATABASE_URL passwords, not POSTGRES_PASSWORD.

# DB connection strings — non-superuser roles created by init-roles.sql.
# Embedded passwords must match REVERIE_APP_PASSWORD /
# REVERIE_INGESTION_PASSWORD set in `staging.env.bootstrap.example`.
DATABASE_URL=postgres://reverie_app:<password>@reverie-postgres:5432/reverie
INGESTION_DATABASE_URL=postgres://reverie_ingestion:<password>@reverie-postgres:5432/reverie

# SPA dist served by the backend; matches Dockerfile COPY target.
REVERIE_FRONTEND_DIST_PATH=/srv/frontend

# Reverie config (subset — see backend/CLAUDE.md and docs/security/ for full).
REVERIE_PORT=3000
REVERIE_OPERATOR_CONTACT=
REVERIE_LOG_LEVEL=info

# OIDC (if integrated — gate provisioning is out-of-tree).
REVERIE_OIDC_ISSUER_URL=
REVERIE_OIDC_CLIENT_ID=
REVERIE_OIDC_CLIENT_SECRET=
REVERIE_OIDC_REDIRECT_URL=
