  "query": "INSERT INTO users (oidc_subject, display_name, email) VALUES ($1, $2, $3) ON CONFLICT (oidc_subject) DO UPDATE SET display_name = EXCLUDED.display_name, email = EXCLUDED.email, updated_at = now() RETURNING id, oidc_subject, display_name, email, role AS \"role: Role\", is_child, created_at, updated_at, session_version, theme_preference AS \"theme_preference: ThemePreference\"",
