  "query": "SELECT m.work_id, m.isbn_10, m.isbn_13, m.publisher, m.pub_date, w.title, w.description, w.language, (SELECT a.name FROM work_authors wa JOIN authors a ON a.id = wa.author_id WHERE wa.work_id = w.id ORDER BY wa.position LIMIT 1) AS first_author FROM manifestations m JOIN works w ON w.id = m.work_id WHERE m.id = $1",
